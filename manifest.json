{
  "manifest_version": 3,
  "name": "CrawlSub",
  "version": "0.1.0",
  "description": "Capture and download subtitles from tv360.vn and fptplay.vn",
  "icons": {
    "16": "icons/icon@16.png",
    "32": "icons/icon@32.png",
    "48": "icons/icon@48.png",
    "128": "icons/icon@128.png"
  },
  "action": {
    "default_title": "CrawlSub",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "32": "icons/icon@32.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "https://*.tv360.vn/*",
    "https://*.fptplay.vn/*",
    "https://*.fptplay.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.tv360.vn/*", "https://*.fptplay.vn/*"],
      "js": ["src/providers/tv360.js", "src/providers/fptplay.js", "src/providers/registry.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
